#!/bin/bash
# Backs up the wx01 database to a timestamped SQL file.
# Usage: wx01-backup [output-dir]
#
# Defaults to /var/lib/wx01/backups/

set -euo pipefail

CONTAINER_NAME="wx01-db"
BACKUP_DIR="${1:-/var/lib/wx01/backups}"
TIMESTAMP=$(date +%Y%m%d-%H%M%S)
BACKUP_FILE="${BACKUP_DIR}/wx01-${TIMESTAMP}.sql.gz"

mkdir -p "$BACKUP_DIR"

echo "Backing up wx01 to ${BACKUP_FILE}..."
docker exec "$CONTAINER_NAME" pg_dump -U wx01 --no-owner --no-privileges wx01 \
  | gzip > "$BACKUP_FILE"

SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
echo "Done. ${BACKUP_FILE} (${SIZE})"

# Keep last 30 backups, remove older ones
ls -t "${BACKUP_DIR}"/wx01-*.sql.gz 2>/dev/null | tail -n +31 | xargs -r rm -f
echo "Retained last 30 backups."
